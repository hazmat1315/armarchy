#!/bin/bash

# Omarchy Limine-Snapper Sync
# Syncs Limine boot entries with Snapper snapshots
# Based on limine-snapper-sync Java application

set -e

# Source the limine library
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
if [[ -f "$SCRIPT_DIR/omarchy-limine-lib" ]]; then
  source "$SCRIPT_DIR/omarchy-limine-lib"
else
  echo "ERROR: omarchy-limine-lib not found"
  exit 1
fi

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Configuration
MAX_SNAPSHOT_ENTRIES=10
SNAPPER_CONFIG="root"

# Print functions (reuse library functions with different prefix)
print_info() {
  lib_print_info "$1"
}

print_success() {
  lib_print_success "$1"
}

print_warning() {
  lib_print_warning "$1"
}

print_error() {
  lib_print_error "$1"
}

# Get snapper snapshots
get_snapper_snapshots() {
  local snapshots=()

  # Debug: Check if snapper works
  if ! snapper -c "$SNAPPER_CONFIG" list >/dev/null 2>&1; then
    print_warning "Unable to access snapper snapshots for config: $SNAPPER_CONFIG"
    return 1
  fi

  # Get snapshots from snapper, skip header and snapshot 0
  # Snapper uses box-drawing character │ as separator
  while IFS='│' read -r num type pre date user cleanup desc userdata; do
    # Clean up the fields
    num=$(echo "$num" | xargs)
    date=$(echo "$date" | xargs)
    desc=$(echo "$desc" | xargs)

    # Skip empty lines, header, and snapshot 0
    if [[ -n "$num" && "$num" =~ ^[0-9]+$ && "$num" != "0" ]]; then
      # Default description if empty
      if [[ -z "$desc" || "$desc" == "" ]]; then
        desc="Snapshot $num"
      fi
      echo "$num|$date|$desc"
    fi
  done < <(snapper -c "$SNAPPER_CONFIG" list 2>/dev/null | grep -E "^[[:space:]]*[0-9]")
}

# Convert snapper date to UTC
convert_to_utc() {
  local snapper_date="$1"

  # Snapper format is usually "YYYY-MM-DD HH:MM:SS"
  # Convert to UTC format expected by manifest
  if date -d "$snapper_date" -u +"%Y-%m-%d %H:%M:%S" 2>/dev/null; then
    return 0
  else
    # Fallback to current time if parsing fails
    date -u +"%Y-%m-%d %H:%M:%S"
  fi
}

# Check if snapshot needs to be added
should_add_snapshot() {
  local snapshot_id="$1"
  local snapshot_utc="$2"

  local manifest=$(get_manifest)
  local last_utc=$(echo "$manifest" | jq -r '.lastUTCTime // ""')
  local last_id=$(echo "$manifest" | jq '.lastSnapshotID // 0')

  # If no previous snapshots, add this one
  if [[ -z "$last_utc" || "$last_id" -eq 0 ]]; then
    return 0
  fi

  # Compare timestamps
  local current_epoch=$(date -d "$snapshot_utc" +%s 2>/dev/null || echo "0")
  local last_epoch=$(date -d "$last_utc" +%s 2>/dev/null || echo "0")

  if [[ "$current_epoch" -gt "$last_epoch" ]]; then
    return 0 # Should add
  elif [[ "$current_epoch" -eq "$last_epoch" && "$snapshot_id" -ne "$last_id" ]]; then
    return 0 # Same time but different ID
  fi

  return 1 # Should not add
}

# Remove outdated snapshots from manifest
clean_outdated_snapshots() {
  local manifest=$(get_manifest)
  local snapper_ids=()

  # Get all current snapper snapshot IDs
  while IFS='|' read -r id date desc; do
    if [[ -n "$id" ]]; then
      snapper_ids+=("$id")
    fi
  done < <(get_snapper_snapshots)

  # Create array as JSON for jq processing (handle empty array)
  local ids_json
  if [[ ${#snapper_ids[@]} -eq 0 ]]; then
    ids_json="[]"
  else
    ids_json=$(printf '%s\n' "${snapper_ids[@]}" | jq -R . | jq -s 'map(tonumber)')
  fi

  # Filter manifest to remove entries not in snapper list
  local updated_manifest=$(echo "$manifest" | jq \
    --argjson valid_ids "$ids_json" \
    '.snapshotEntries = [.snapshotEntries[] | select([.snapperEntry.snapshotID] | inside($valid_ids))]')

  # Check if any entries were removed
  local old_count=$(echo "$manifest" | jq '.snapshotEntries | length')
  local new_count=$(echo "$updated_manifest" | jq '.snapshotEntries | length')

  if [[ "$old_count" -ne "$new_count" ]]; then
    update_manifest "$updated_manifest"
    print_success "Removed $((old_count - new_count)) outdated snapshot entries"
    return 0
  fi

  return 1
}

# Prune excess snapshots based on MAX_SNAPSHOT_ENTRIES
prune_excess_snapshots() {
  local manifest=$(get_manifest)
  local count=$(echo "$manifest" | jq '.snapshotEntries | length')
  local max_allowed="$MAX_SNAPSHOT_ENTRIES"

  if [[ "$count" -le "$max_allowed" ]]; then
    return 0
  fi

  print_info "Pruning excess snapshots (keeping $max_allowed out of $count)"

  # Keep only the most recent entries
  local updated_manifest=$(echo "$manifest" | jq \
    --argjson max "$max_allowed" \
    '.snapshotEntries = (.snapshotEntries | sort_by(.snapperEntry.snapshotID) | .[-$max:])')

  update_manifest "$updated_manifest"
  print_success "Pruned $((count - max_allowed)) excess snapshot entries"
}

# Sync snapshots with manifest
sync_snapshots() {
  local added_count=0
  local updated_count=0

  print_info "Scanning Snapper snapshots..."

  # Clean outdated entries first
  if clean_outdated_snapshots; then
    updated_count=$((updated_count + 1))
  fi

  # Process each snapper snapshot
  while IFS='|' read -r id date desc; do
    if [[ -z "$id" ]]; then
      continue
    fi

    local utc_time=$(convert_to_utc "$date")
    local local_time="$date"

    # Check if we should add this snapshot
    if should_add_snapshot "$id" "$utc_time"; then
      print_info "Adding snapshot $id to manifest..."

      # Add snapshot to manifest
      local updated_manifest=$(add_snapshot_to_manifest "$id" "$desc" "$utc_time" "$local_time")
      update_manifest "$updated_manifest"

      added_count=$((added_count + 1))
      print_success "Added snapshot $id: $desc"
    fi

  done < <(get_snapper_snapshots | sort -t'|' -k1,1n) # Sort by ID numerically

  # Prune excess entries
  prune_excess_snapshots

  print_info "Sync complete: $added_count added, $updated_count cleaned"

  return 0
}

# Generate complete Limine configuration
generate_limine_config() {
  local manifest=$(get_manifest)
  local config_header=""
  local config_entries=""

  # Read existing limine.conf header (everything before first entry)
  if [[ -f "$LIMINE_CONFIG_PATH" ]]; then
    config_header=$(awk '/^:/{exit} {print}' "$LIMINE_CONFIG_PATH")
  fi

  # If no header exists, create a basic one
  if [[ -z "$config_header" ]]; then
    config_header="# Limine Configuration
# Generated by omarchy-limine-snapper-sync

TIMEOUT=5
GRAPHICS=yes
MENU_RESOLUTION=1024x768
THEME_COLOURS=0x00000000 0x00ffffff 0x00ffffff 0x00000000 0x00ffffff

"
  fi

  # Generate entries for each snapshot
  local entry_count=$(echo "$manifest" | jq '.snapshotEntries | length')

  for ((i = 0; i < entry_count; i++)); do
    local snapshot_entry=$(echo "$manifest" | jq ".snapshotEntries[$i]")
    local snapshot_id=$(echo "$snapshot_entry" | jq '.snapperEntry.snapshotID')

    local limine_entry=$(generate_limine_entry "$snapshot_id")
    if [[ -n "$limine_entry" ]]; then
      config_entries+="$limine_entry"
      config_entries+=$'\n'
    fi
  done

  echo "$config_header"
  echo "$config_entries"
}

# Update Limine configuration file using omarchy-limine-update
update_limine_config() {
  # Use the existing omarchy-limine-update script which knows how to handle the config format
  local update_script=""

  # Find omarchy-limine-update script
  if [[ -f "$(dirname "$0")/omarchy-limine-update" ]]; then
    update_script="$(dirname "$0")/omarchy-limine-update"
  elif command -v omarchy-limine-update >/dev/null 2>&1; then
    update_script="omarchy-limine-update"
  else
    print_warning "omarchy-limine-update not found, using fallback method"
    # Fallback to original method
    if [[ ! -f "$LIMINE_CONFIG_PATH" ]]; then
      print_warning "Limine config not found, creating new one: $LIMINE_CONFIG_PATH"
      mkdir -p "$(dirname "$LIMINE_CONFIG_PATH")"
    fi

    # Backup existing config
    if [[ -f "$LIMINE_CONFIG_PATH" ]]; then
      cp "$LIMINE_CONFIG_PATH" "$LIMINE_CONFIG_PATH.backup.$(date +%s)"
    fi

    # Generate and write new config
    generate_limine_config >"$LIMINE_CONFIG_PATH"
    print_success "Updated Limine configuration: $LIMINE_CONFIG_PATH"
    return 0
  fi

  # Use omarchy-limine-update to handle the config update
  print_info "Using $update_script to update Limine configuration"
  if "$update_script" >/dev/null 2>&1; then
    print_success "Updated Limine configuration via omarchy-limine-update"
  else
    print_error "Failed to update Limine configuration"
    return 1
  fi
}

# Display usage information
show_usage() {
  echo "Usage: $0 [OPTIONS]"
  echo "Sync Limine boot entries with Snapper snapshots"
  echo ""
  echo "Options:"
  echo "  --max-entries N    Maximum number of snapshot entries to keep (default: $MAX_SNAPSHOT_ENTRIES)"
  echo "  --snapper-config C Snapper configuration name (default: $SNAPPER_CONFIG)"
  echo "  --dry-run         Show what would be done without making changes"
  echo "  --help, -h        Show this help message"
  echo ""
  echo "Examples:"
  echo "  $0                           # Sync with default settings"
  echo "  $0 --max-entries 15          # Keep up to 15 snapshot entries"
  echo "  $0 --dry-run                 # Preview changes without applying"
}

# Main function
main() {
  local dry_run=false

  # Parse command line arguments
  while [[ $# -gt 0 ]]; do
    case $1 in
    --max-entries)
      if [[ -n "$2" && "$2" =~ ^[0-9]+$ ]]; then
        MAX_SNAPSHOT_ENTRIES="$2"
        shift 2
      else
        print_error "Invalid max entries value: $2"
        exit 1
      fi
      ;;
    --snapper-config)
      if [[ -n "$2" ]]; then
        SNAPPER_CONFIG="$2"
        shift 2
      else
        print_error "Snapper config name required"
        exit 1
      fi
      ;;
    --dry-run)
      dry_run=true
      shift
      ;;
    --help | -h)
      show_usage
      exit 0
      ;;
    *)
      print_error "Unknown option: $1"
      echo "Use --help for usage information"
      exit 1
      ;;
    esac
  done

  # Check if running as root, if not re-run with sudo
  if [[ $EUID -ne 0 ]]; then
    print_info "Root privileges required, elevating with sudo..."
    exec sudo "$0" "$@"
    exit $?
  fi

  # Check dependencies
  if ! command -v snapper &>/dev/null; then
    print_error "snapper is not installed or not in PATH"
    exit 1
  fi

  # Initialize library
  init_limine_lib
  if ! check_dependencies; then
    print_error "Missing dependencies for kernel versioning"
    exit 1
  fi

  print_info "Starting Limine-Snapper sync (max entries: $MAX_SNAPSHOT_ENTRIES, config: $SNAPPER_CONFIG)"

  if [[ "$dry_run" == "true" ]]; then
    print_warning "Running in DRY-RUN mode - no changes will be made"
    print_info "Would perform the following operations:"
    echo "  1. Scan Snapper snapshots in config '$SNAPPER_CONFIG'"
    echo "  2. Clean outdated entries from manifest"
    echo "  3. Add new snapshots to manifest with kernel file tracking"
    echo "  4. Prune excess entries (keeping $MAX_SNAPSHOT_ENTRIES)"
    echo "  5. Update Limine configuration with snapshot boot entries"
    echo "  6. Backup and copy kernel files to history directory"
    return 0
  fi

  # Perform sync
  if sync_snapshots; then
    update_limine_config
    print_success "Limine-Snapper sync completed successfully"
  else
    print_error "Sync failed"
    exit 1
  fi
}

# Run main function with all arguments
main "$@"

