#!/bin/bash

# Omarchy Limine-Snapper List
# Display available snapshots in Limine boot menu
# Based on limine-snapper-sync Java application

set -e

# Source the limine library
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
if [[ -f "$SCRIPT_DIR/omarchy-limine-lib" ]]; then
  source "$SCRIPT_DIR/omarchy-limine-lib"
else
  echo "ERROR: omarchy-limine-lib not found"
  exit 1
fi

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Print functions
print_info() {
  lib_print_info "$1"
}

print_success() {
  lib_print_success "$1"
}

print_warning() {
  lib_print_warning "$1"
}

print_error() {
  lib_print_error "$1"
}

# Display detailed snapshot information
show_detailed_info() {
  local snapshot_id="$1"
  local manifest=$(get_manifest)

  local snapshot_entry=$(echo "$manifest" | jq \
    --argjson id "$snapshot_id" \
    '.snapshotEntries[] | select(.snapperEntry.snapshotID == $id)')

  if [[ -z "$snapshot_entry" ]]; then
    print_error "Snapshot $snapshot_id not found in manifest"
    return 1
  fi

  echo ""
  echo "Snapshot Details:"
  echo "=================="

  local id=$(echo "$snapshot_entry" | jq -r '.snapperEntry.snapshotID')
  local local_time=$(echo "$snapshot_entry" | jq -r '.snapperEntry.localTime')
  local utc_time=$(echo "$snapshot_entry" | jq -r '.snapperEntry.utcTime')
  local description=$(echo "$snapshot_entry" | jq -r '.snapperEntry.properties.description')

  echo "ID:          $id"
  echo "Date:        $local_time"
  echo "UTC Time:    $utc_time"
  echo "Description: $description"

  # Show kernel files
  local kernel_count=$(echo "$snapshot_entry" | jq '.kernelEntries[0].imageDetails | length')
  if [[ "$kernel_count" -gt 0 ]]; then
    echo ""
    echo "Kernel Files:"
    echo "-------------"
    for ((i = 0; i < kernel_count; i++)); do
      local image=$(echo "$snapshot_entry" | jq ".kernelEntries[0].imageDetails[$i]")
      local filename=$(echo "$image" | jq -r '.fileName')
      local limine_key=$(echo "$image" | jq -r '.limineKey')
      local hash_name=$(echo "$image" | jq -r '.fileHashName')

      echo "$limine_key: $filename ($hash_name)"
    done
  fi

  # All snapshots in manifest are available for restore
  echo ""
  echo "Status: Available for restore"
}

# List snapshots in table format
list_snapshots_table() {
  local manifest=$(get_manifest)
  local count=$(echo "$manifest" | jq '.snapshotEntries | length')

  if [[ "$count" -eq 0 ]]; then
    print_warning "No snapshots found in manifest"
    echo "Run 'omarchy-limine-snapper-sync' to sync with Snapper snapshots"
    return 0
  fi

  echo ""
  printf "%-4s %-20s %-10s %s\n" "ID" "Date" "Files" "Description"
  printf "%-4s %-20s %-10s %s\n" "----" "--------------------" "----------" "-----------"

  for ((i = 0; i < count; i++)); do
    local entry=$(echo "$manifest" | jq ".snapshotEntries[$i]")
    local id=$(echo "$entry" | jq -r '.snapperEntry.snapshotID')
    local date=$(echo "$entry" | jq -r '.snapperEntry.localTime' | cut -d' ' -f1) # Just date part
    local desc=$(echo "$entry" | jq -r '.snapperEntry.properties.description')
    local file_count=$(echo "$entry" | jq '.kernelEntries[0].imageDetails | length')

    # Note: Don't check snapshot directory availability since snapshots
    # may be in unmounted subvolumes (like root/.snapshots) but still bootable
    local status=""

    printf "%-4s %-20s %-10s %s%s\n" "$id" "$date" "$file_count" "$desc" "$status"
  done

  echo ""
  echo "Total: $count snapshots in boot menu"
}

# Show manifest statistics
show_statistics() {
  local manifest=$(get_manifest)
  local count=$(echo "$manifest" | jq '.snapshotEntries | length')
  local last_id=$(echo "$manifest" | jq '.lastSnapshotID // 0')
  local last_time=$(echo "$manifest" | jq -r '.lastLocalTime // "Never"')
  local machine_id=$(echo "$manifest" | jq -r '.machineId // "Unknown"')

  echo ""
  echo "Manifest Statistics:"
  echo "==================="
  echo "Total snapshots:    $count"
  echo "Last snapshot ID:   $last_id"
  echo "Last sync time:     $last_time"
  echo "Machine ID:         $machine_id"
  echo "Manifest path:      $MANIFEST_PATH"
  echo "History directory:  $HISTORY_DIR"

  # Count files in history
  if [[ -d "$HISTORY_DIR" ]]; then
    local history_count=$(find "$HISTORY_DIR" -type f 2>/dev/null | wc -l)
    local history_size=$(du -sh "$HISTORY_DIR" 2>/dev/null | cut -f1)
    echo "History files:      $history_count files ($history_size)"
  else
    echo "History files:      Directory not found"
  fi
}

# Display usage information
show_usage() {
  echo "Usage: $0 [OPTIONS] [SNAPSHOT_ID]"
  echo "Display available snapshots in Limine boot menu"
  echo ""
  echo "Options:"
  echo "  --detailed, -d     Show detailed information for all snapshots"
  echo "  --stats, -s        Show manifest statistics"
  echo "  --help, -h         Show this help message"
  echo ""
  echo "Arguments:"
  echo "  SNAPSHOT_ID        Show detailed information for specific snapshot"
  echo ""
  echo "Examples:"
  echo "  $0                 # List all snapshots in table format"
  echo "  $0 --detailed      # Show detailed info for all snapshots"
  echo "  $0 123             # Show detailed info for snapshot 123"
  echo "  $0 --stats         # Show manifest and history statistics"
}

# Main function
main() {
  local detailed=false
  local show_stats=false
  local target_id=""

  # Parse command line arguments
  while [[ $# -gt 0 ]]; do
    case $1 in
    --detailed | -d)
      detailed=true
      shift
      ;;
    --stats | -s)
      show_stats=true
      shift
      ;;
    --help | -h)
      show_usage
      exit 0
      ;;
    [0-9]*)
      target_id="$1"
      shift
      ;;
    *)
      print_error "Unknown option: $1"
      echo "Use --help for usage information"
      exit 1
      ;;
    esac
  done

  # Initialize library
  init_limine_lib
  if ! check_dependencies; then
    print_error "Missing dependencies for kernel versioning"
    exit 1
  fi

  # Show statistics if requested
  if [[ "$show_stats" == "true" ]]; then
    show_statistics
    return 0
  fi

  # Show specific snapshot details
  if [[ -n "$target_id" ]]; then
    show_detailed_info "$target_id"
    return 0
  fi

  # Show detailed info for all snapshots
  if [[ "$detailed" == "true" ]]; then
    local manifest=$(get_manifest)

    # Get all snapshot IDs and process them
    local snapshot_ids=($(echo "$manifest" | jq -r '.snapshotEntries[].snapperEntry.snapshotID' | sort -n))

    for snapshot_id in "${snapshot_ids[@]}"; do
      show_detailed_info "$snapshot_id"
      echo ""
    done
    return 0
  fi

  # Default: show table format
  print_info "Limine Snapshot Boot Entries:"
  list_snapshots_table
}

# Run main function with all arguments
main "$@"

