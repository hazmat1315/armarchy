#!/bin/bash

# Omarchy Limine-Snapper Library
# Shared functions for kernel versioning and boot management
# Based on limine-snapper-sync functionality

set -e

# Colors for output (reuse from main script)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Global configuration
LIMINE_CONFIG_PATH=""
ESP_PATH=""
MACHINE_ID=""
HISTORY_DIR=""
MANIFEST_PATH=""
HASH_FUNCTION="sha256"

# Initialize library configuration
init_limine_lib() {
  local config_file="/etc/default/limine"

  # Try to read configuration
  if [[ -f "$config_file" ]]; then
    source "$config_file" 2>/dev/null || true
  fi

  # Set defaults if not configured
  ESP_PATH="${ESP_PATH:-/boot}"
  MACHINE_ID="${MACHINE_ID:-$(cat /etc/machine-id 2>/dev/null || echo "default")}"
  HISTORY_DIR="$ESP_PATH/$MACHINE_ID/limine_history"
  MANIFEST_PATH="$ESP_PATH/$MACHINE_ID/snapshots.json"
  LIMINE_CONFIG_PATH="${LIMINE_CONFIG_PATH:-$ESP_PATH/limine.conf}"
  HASH_FUNCTION="${HASH_FUNCTION:-sha256}"

  # Create necessary directories
  mkdir -p "$HISTORY_DIR"
  mkdir -p "$(dirname "$MANIFEST_PATH")"
}

# Print functions
lib_print_info() {
  echo -e "${BLUE}$1${NC}"
}

lib_print_success() {
  echo -e "${GREEN}✓ $1${NC}"
}

lib_print_warning() {
  echo -e "${YELLOW}⚠ $1${NC}"
}

lib_print_error() {
  echo -e "${RED}ERROR: $1${NC}"
}

# Hash calculation function
calculate_file_hash() {
  local file_path="$1"

  if [[ ! -f "$file_path" ]]; then
    echo "FILE_NOT_FOUND"
    return 1
  fi

  case "$HASH_FUNCTION" in
  "sha256")
    sha256sum "$file_path" | cut -d' ' -f1
    ;;
  "sha1")
    sha1sum "$file_path" | cut -d' ' -f1
    ;;
  "blake3")
    if command -v b3sum >/dev/null 2>&1; then
      b3sum "$file_path" | cut -d' ' -f1
    else
      lib_print_error "b3sum not found but HASH_FUNCTION=blake3"
      return 1
    fi
    ;;
  *)
    lib_print_error "Unknown hash function: $HASH_FUNCTION"
    return 1
    ;;
  esac
}

# Find kernel files in a directory
find_kernel_files() {
  local search_dir="$1"
  local files=()

  if [[ ! -d "$search_dir" ]]; then
    return 1
  fi

  # Find common kernel file patterns (exclude fallback to save space)
  while IFS= read -r -d '' file; do
    # Skip fallback images to save ESP space
    if [[ "$(basename "$file")" == *"fallback"* ]]; then
      continue
    fi
    files+=("$file")
  done < <(find "$search_dir" -type f \( \
    -name "vmlinuz*" -o \
    -name "bzImage*" -o \
    -name "kernel*" -o \
    -name "initramfs*" -o \
    -name "initrd*" -o \
    -name "*.img" -o \
    -name "*.efi" \
    \) -print0 2>/dev/null)

  printf '%s\n' "${files[@]}"
}

# Create image detail object (mimics Java ImageDetail)
create_image_detail() {
  local file_path="$1"
  local limine_key="$2"

  if [[ ! -f "$file_path" ]]; then
    return 1
  fi

  local filename=$(basename "$file_path")
  local dir_path=$(dirname "$file_path")
  local relative_dir="${dir_path#$ESP_PATH/}"
  local file_hash=$(calculate_file_hash "$file_path")
  local hash_filename="${HASH_FUNCTION}_${file_hash}"

  # Create JSON object
  jq -n \
    --arg limine_key "$limine_key" \
    --arg filename "$filename" \
    --arg file_hash_name "$hash_filename" \
    --arg dir_path "$relative_dir" \
    --arg file_path_line "$file_path" \
    --arg snapshot_file_path_line "/$MACHINE_ID/limine_history/$hash_filename" \
    '{
            limineKey: $limine_key,
            fileName: $filename,
            fileHashName: $file_hash_name,
            dirPath: $dir_path,
            filePathLine: $file_path_line,
            snapshotFilePathLine: $snapshot_file_path_line,
            properties: {}
        }'
}

# Copy file to history with deduplication
copy_to_history() {
  local source_file="$1"
  local image_detail_json="$2"

  local hash_filename=$(echo "$image_detail_json" | jq -r '.fileHashName')
  local target_path="$HISTORY_DIR/$hash_filename"

  if [[ -f "$target_path" ]]; then
    # File already exists in history, verify integrity
    local existing_hash=$(calculate_file_hash "$target_path")
    local expected_hash=$(echo "$hash_filename" | cut -d'_' -f2-)

    if [[ "$existing_hash" != "$expected_hash" ]]; then
      lib_print_warning "History file corrupted, replacing: $hash_filename"
      cp "$source_file" "$target_path"
    fi
    return 0
  fi

  # Copy file to history
  if cp "$source_file" "$target_path"; then
    lib_print_success "Copied to history: $hash_filename"
    return 0
  else
    lib_print_error "Failed to copy to history: $source_file"
    return 1
  fi
}

# Initialize empty manifest if it doesn't exist
init_manifest() {
  if [[ ! -f "$MANIFEST_PATH" ]]; then
    local machine_uuid=""
    if [[ -f "/sys/class/dmi/id/product_uuid" ]]; then
      machine_uuid=$(cat /sys/class/dmi/id/product_uuid 2>/dev/null || echo "")
    fi

    jq -n \
      --arg uuid "$machine_uuid" \
      --arg machine_id "$MACHINE_ID" \
      '{
                uuid: $uuid,
                machineId: $machine_id,
                lastSnapshotID: 0,
                lastLocalTime: "",
                lastUTCTime: "",
                snapshotEntries: []
            }' >"$MANIFEST_PATH"

    lib_print_success "Created new manifest: $MANIFEST_PATH"
  fi
}

# Get manifest data
get_manifest() {
  init_manifest
  cat "$MANIFEST_PATH"
}

# Update manifest
update_manifest() {
  local new_manifest="$1"

  # Validate JSON before writing
  if ! echo "$new_manifest" | jq '.' >"$MANIFEST_PATH.tmp" 2>/dev/null; then
    lib_print_error "Failed to update manifest - invalid JSON"
    return 1
  fi

  # Only replace if temp file has content
  if [[ -s "$MANIFEST_PATH.tmp" ]]; then
    mv "$MANIFEST_PATH.tmp" "$MANIFEST_PATH"
    lib_print_success "Updated manifest"
  else
    lib_print_error "Failed to update manifest - empty result"
    rm -f "$MANIFEST_PATH.tmp"
    return 1
  fi
}

# Create kernel entry for current system
create_current_kernel_entry() {
  local snapshot_id="$1"
  local kernel_files=()
  local image_details=()

  # Find all kernel files in ESP
  while IFS= read -r file; do
    if [[ -n "$file" ]]; then
      kernel_files+=("$file")
    fi
  done < <(find_kernel_files "$ESP_PATH")

  # Create image details for each file
  for file in "${kernel_files[@]}"; do
    local relative_path="${file#$ESP_PATH/}"
    local limine_key=""

    # Determine Limine key based on file type
    case "$(basename "$file")" in
    vmlinuz* | bzImage* | kernel* | *.efi)
      limine_key="KERNEL_PATH"
      ;;
    initramfs* | initrd* | *.img)
      limine_key="MODULE_PATH"
      ;;
    *)
      limine_key="PATH"
      ;;
    esac

    local image_detail=$(create_image_detail "$file" "$limine_key")
    if [[ $? -eq 0 && -n "$image_detail" ]]; then
      # Validate JSON before adding
      if echo "$image_detail" | jq '.' >/dev/null 2>&1; then
        image_details+=("$image_detail")
        # Copy file to history
        copy_to_history "$file" "$image_detail" >/dev/null 2>&1 || true
      fi
    fi
  done

  # Create kernel entry JSON with fallback for empty images
  local images_json="[]"
  if [[ ${#image_details[@]} -gt 0 ]]; then
    images_json=$(printf '%s\n' "${image_details[@]}" | jq -s '.' 2>/dev/null || echo "[]")
  fi

  # Create the JSON, ensuring all required fields are present
  jq -n \
    --arg name "Current System" \
    --argjson images "$images_json" \
    '{
            name: $name,
            leadingSpaces: "",
            optionDetails: [],
            imageDetails: $images,
            cmdlineDetails: [],
            clearBootConfigs: [],
            subKernels: [],
            snapshotBootConfigs: []
        }' 2>/dev/null || echo '{
            "name": "Current System",
            "leadingSpaces": "",
            "optionDetails": [],
            "imageDetails": [],
            "cmdlineDetails": [],
            "clearBootConfigs": [],
            "subKernels": [],
            "snapshotBootConfigs": []
        }'
}

# Create snapshot entry
create_snapshot_entry() {
  local snapshot_id="$1"
  local description="$2"
  local utc_time="$3"
  local local_time="$4"

  # Validate inputs
  if [[ -z "$snapshot_id" || -z "$description" || -z "$utc_time" || -z "$local_time" ]]; then
    lib_print_error "Invalid parameters for snapshot entry"
    return 1
  fi

  local kernel_entry=$(create_current_kernel_entry "$snapshot_id")

  # Validate kernel entry JSON
  if ! echo "$kernel_entry" | jq '.' >/dev/null 2>&1; then
    lib_print_warning "Invalid kernel entry JSON for snapshot $snapshot_id, using empty entry"
    kernel_entry='{
            "name": "Current System",
            "leadingSpaces": "",
            "optionDetails": [],
            "imageDetails": [],
            "cmdlineDetails": [],
            "clearBootConfigs": [],
            "subKernels": [],
            "snapshotBootConfigs": []
        }'
  fi

  # Create snapshot entry with error handling
  jq -n \
    --argjson snapshot_id "$snapshot_id" \
    --arg description "$description" \
    --arg utc_time "$utc_time" \
    --arg local_time "$local_time" \
    --argjson kernel_entries "[$kernel_entry]" \
    '{
            snapperEntry: {
                snapshotID: $snapshot_id,
                utcTime: $utc_time,
                localTime: $local_time,
                timeId: ($utc_time + "|" + ($snapshot_id | tostring)),
                properties: {
                    description: $description
                }
            },
            kernelEntries: $kernel_entries
        }' 2>/dev/null || {
    lib_print_error "Failed to create snapshot entry JSON"
    return 1
  }
}

# Add snapshot to manifest
add_snapshot_to_manifest() {
  local snapshot_id="$1"
  local description="$2"
  local utc_time="$3"
  local local_time="$4"

  # Validate inputs
  if [[ -z "$snapshot_id" || -z "$description" || -z "$utc_time" || -z "$local_time" ]]; then
    lib_print_error "Invalid parameters for add_snapshot_to_manifest"
    return 1
  fi

  local manifest=$(get_manifest)
  if [[ -z "$manifest" ]]; then
    lib_print_error "Failed to get manifest"
    return 1
  fi

  local snapshot_entry=$(create_snapshot_entry "$snapshot_id" "$description" "$utc_time" "$local_time")
  if [[ $? -ne 0 || -z "$snapshot_entry" ]]; then
    lib_print_error "Failed to create snapshot entry for $snapshot_id"
    return 1
  fi

  # Validate snapshot entry JSON
  if ! echo "$snapshot_entry" | jq '.' >/dev/null 2>&1; then
    lib_print_error "Invalid snapshot entry JSON for $snapshot_id"
    return 1
  fi

  # Create updated manifest
  local updated_manifest=$(echo "$manifest" | jq \
    --argjson entry "$snapshot_entry" \
    --arg utc_time "$utc_time" \
    --arg local_time "$local_time" \
    --argjson snapshot_id "$snapshot_id" \
    '.snapshotEntries += [$entry] |
         .lastSnapshotID = $snapshot_id |
         .lastUTCTime = $utc_time |
         .lastLocalTime = $local_time' 2>/dev/null)

  if [[ $? -ne 0 || -z "$updated_manifest" ]]; then
    lib_print_error "Failed to update manifest JSON for snapshot $snapshot_id"
    return 1
  fi

  echo "$updated_manifest"
}

# Get snapshot entry by ID
get_snapshot_entry() {
  local snapshot_id="$1"
  local manifest=$(get_manifest)

  echo "$manifest" | jq \
    --argjson id "$snapshot_id" \
    '.snapshotEntries[] | select(.snapperEntry.snapshotID == $id)'
}

# List all snapshots
list_snapshots() {
  local manifest=$(get_manifest)

  echo "$manifest" | jq -r '.snapshotEntries[] |
        [.snapperEntry.snapshotID, .snapperEntry.localTime, .snapperEntry.properties.description] |
        @tsv' |
    while IFS=$'\t' read -r id time desc; do
      printf "%-4s %-20s %s\n" "$id" "$time" "$desc"
    done
}

# Restore kernel files for a snapshot
restore_kernel_files() {
  local snapshot_id="$1"
  local snapshot_entry=$(get_snapshot_entry "$snapshot_id")

  if [[ -z "$snapshot_entry" ]]; then
    lib_print_error "Snapshot $snapshot_id not found in manifest"
    return 1
  fi

  lib_print_info "Restoring kernel files for snapshot $snapshot_id"

  # Extract image details from snapshot entry
  local image_count=$(echo "$snapshot_entry" | jq '.kernelEntries[0].imageDetails | length')

  for ((i = 0; i < image_count; i++)); do
    local image_detail=$(echo "$snapshot_entry" | jq ".kernelEntries[0].imageDetails[$i]")
    local hash_filename=$(echo "$image_detail" | jq -r '.fileHashName')
    local target_dir="$ESP_PATH/$(echo "$image_detail" | jq -r '.dirPath')"
    local target_filename=$(echo "$image_detail" | jq -r '.fileName')
    local source_path="$HISTORY_DIR/$hash_filename"
    local target_path="$target_dir/$target_filename"

    if [[ ! -f "$source_path" ]]; then
      lib_print_warning "History file missing: $hash_filename"
      continue
    fi

    # Create target directory if needed
    mkdir -p "$target_dir"

    # Copy file from history
    if cp "$source_path" "$target_path"; then
      lib_print_success "Restored: $target_filename"
    else
      lib_print_error "Failed to restore: $target_filename"
    fi
  done
}

# Backup current kernel files
backup_current_kernel_files() {
  local description="$1"
  local utc_time=$(date -u +"%Y-%m-%d %H:%M:%S")
  local local_time=$(date +"%Y-%m-%d %H:%M:%S")

  # Find next available snapshot ID
  local manifest=$(get_manifest)
  local last_id=$(echo "$manifest" | jq '.lastSnapshotID // 0')
  local new_id=$((last_id + 1))

  lib_print_info "Backing up current kernel files as snapshot $new_id"

  # Create snapshot entry with current kernel files
  local updated_manifest=$(add_snapshot_to_manifest "$new_id" "$description" "$utc_time" "$local_time")

  # Update manifest
  update_manifest "$updated_manifest"

  echo "$new_id"
}

# Generate Limine configuration entry for snapshot
generate_limine_entry() {
  local snapshot_id="$1"
  local snapshot_entry=$(get_snapshot_entry "$snapshot_id")

  if [[ -z "$snapshot_entry" ]]; then
    return 1
  fi

  local description=$(echo "$snapshot_entry" | jq -r '.snapperEntry.properties.description')
  local date=$(echo "$snapshot_entry" | jq -r '.snapperEntry.localTime')

  echo ""
  echo ":Snapshot $snapshot_id - $description"
  echo "    COMMENT=$date"

  # Generate kernel/module paths from image details
  local image_count=$(echo "$snapshot_entry" | jq '.kernelEntries[0].imageDetails | length')

  for ((i = 0; i < image_count; i++)); do
    local image_detail=$(echo "$snapshot_entry" | jq ".kernelEntries[0].imageDetails[$i]")
    local limine_key=$(echo "$image_detail" | jq -r '.limineKey')
    local snapshot_path=$(echo "$image_detail" | jq -r '.snapshotFilePathLine')

    echo "    $limine_key=boot://$snapshot_path"
  done

  # Add root parameter pointing to snapshot
  echo "    CMDLINE=root=LABEL=ROOT rootflags=subvol=/.snapshots/$snapshot_id/snapshot ro"
}

# Check if jq is available
check_dependencies() {
  if ! command -v jq >/dev/null 2>&1; then
    lib_print_error "jq is required but not installed"
    return 1
  fi

  case "$HASH_FUNCTION" in
  "blake3")
    if ! command -v b3sum >/dev/null 2>&1; then
      lib_print_error "b3sum is required for blake3 but not installed"
      return 1
    fi
    ;;
  esac

  return 0
}

# Sync current snapper snapshots to manifest (for integration with omarchy-limine-update)
add_current_snapshots_to_manifest() {
  if ! command -v snapper >/dev/null 2>&1; then
    return 1
  fi

  # Get current snapshots from snapper
  while IFS='|' read -r num date desc; do
    # Clean up the fields
    num=$(echo "$num" | xargs)
    date=$(echo "$date" | xargs)
    desc=$(echo "$desc" | xargs)

    # Skip empty lines and invalid entries
    if [[ -n "$num" && "$num" != "0" && "$num" =~ ^[0-9]+$ ]]; then
      # Don't check directory - trust snapper output (snapshot may be in unmounted subvol)
      local utc_time=$(date -d "$date" -u +"%Y-%m-%d %H:%M:%S" 2>/dev/null || date -u +"%Y-%m-%d %H:%M:%S")
      local local_time="$date"

      # Check if snapshot already exists in manifest
      local existing=$(get_snapshot_entry "$num" 2>/dev/null || echo "")
      if [[ -z "$existing" ]]; then
        # Add new snapshot to manifest
        local updated_manifest=$(add_snapshot_to_manifest "$num" "$desc" "$utc_time" "$local_time")
        update_manifest "$updated_manifest" >/dev/null 2>&1 || true
      fi
    fi
  done < <(snapper -c root list --columns number,date,description 2>/dev/null | tail -n +3 || true)
}

# Generate snapshot entries for Limine config (for integration with omarchy-limine-update)
generate_snapshot_entries_for_config() {
  local config_file="$1"
  local manifest=$(get_manifest)
  local count=$(echo "$manifest" | jq '.snapshotEntries | length' 2>/dev/null || echo "0")

  # Limit to 5 most recent snapshots (matching original behavior)
  local max_entries=5
  local start_index=$((count > max_entries ? count - max_entries : 0))

  for ((i = start_index; i < count; i++)); do
    local entry=$(echo "$manifest" | jq ".snapshotEntries[$i]" 2>/dev/null)
    if [[ -z "$entry" || "$entry" == "null" ]]; then
      continue
    fi

    local snapshot_id=$(echo "$entry" | jq -r '.snapperEntry.snapshotID' 2>/dev/null)
    local description=$(echo "$entry" | jq -r '.snapperEntry.properties.description' 2>/dev/null)

    # Skip check for snapshot directory - it may be in unmounted subvolume
    # Trust that if it's in the manifest, it came from snapper

    # Add snapshot entry
    echo "    ///Snapshot $snapshot_id - $description" >>"$config_file"
    echo "    comment: Snapshot $snapshot_id with matching kernels" >>"$config_file"
    echo "    protocol: linux" >>"$config_file"

    # Get kernel files for this snapshot from manifest
    local kernel_count=$(echo "$entry" | jq '.kernelEntries[0].imageDetails | length' 2>/dev/null || echo "0")

    if [[ "$kernel_count" -gt 0 ]]; then
      # Use kernel files from history
      local kernel_added=false
      local module_added=false

      for ((j = 0; j < kernel_count; j++)); do
        local image=$(echo "$entry" | jq ".kernelEntries[0].imageDetails[$j]" 2>/dev/null)
        local limine_key=$(echo "$image" | jq -r '.limineKey' 2>/dev/null)
        local snapshot_path=$(echo "$image" | jq -r '.snapshotFilePathLine' 2>/dev/null)

        case "$limine_key" in
        "KERNEL_PATH")
          if [[ "$kernel_added" == "false" ]]; then
            echo "    kernel_path: boot://$snapshot_path" >>"$config_file"
            kernel_added=true
          fi
          ;;
        "MODULE_PATH")
          if [[ "$module_added" == "false" ]]; then
            echo "    module_path: boot://$snapshot_path" >>"$config_file"
            module_added=true
          fi
          ;;
        esac
      done
    else
      # Fallback: use current kernel (with warning)
      echo "    # WARNING: No kernel history for this snapshot" >>"$config_file"
      if [[ "$(uname -m)" == "aarch64" ]]; then
        echo "    kernel_path: boot():/Image" >>"$config_file"
        if [[ -f "/boot/initramfs-linux.img" ]]; then
          echo "    module_path: boot():/initramfs-linux.img" >>"$config_file"
        fi
      else
        local current_kernel=$(ls /boot/vmlinuz-* 2>/dev/null | sort -V | tail -1 | sed 's|/boot/vmlinuz-||' || echo "linux")
        echo "    kernel_path: boot():/vmlinuz-${current_kernel}" >>"$config_file"
        if [[ -f "/boot/initramfs-${current_kernel}.img" ]]; then
          echo "    module_path: boot():/initramfs-${current_kernel}.img" >>"$config_file"
        fi
      fi
    fi

    # Set kernel command line for snapshot (get actual root UUID)
    local snapshot_subvol="root/.snapshots/$snapshot_id/snapshot"
    local root_device=$(findmnt -n -o SOURCE / | sed 's/\[.*\]$//')
    local root_uuid=$(blkid -o value -s UUID "$root_device" 2>/dev/null || blkid | grep 'TYPE="btrfs"' | grep -oP 'UUID="\K[^"]+' | head -1)

    if [[ -n "$root_uuid" ]]; then
      echo "    kernel_cmdline: root=UUID=$root_uuid rootflags=subvol=$snapshot_subvol rw rootfstype=btrfs quiet splash" >>"$config_file"
    else
      echo "    kernel_cmdline: rootflags=subvol=$snapshot_subvol rw rootfstype=btrfs quiet splash" >>"$config_file"
    fi
  done
}

# Export functions for use by other scripts
export -f init_limine_lib
export -f lib_print_info lib_print_success lib_print_warning lib_print_error
export -f calculate_file_hash find_kernel_files create_image_detail
export -f copy_to_history get_manifest update_manifest
export -f create_current_kernel_entry create_snapshot_entry add_snapshot_to_manifest
export -f get_snapshot_entry list_snapshots
export -f restore_kernel_files backup_current_kernel_files
export -f generate_limine_entry check_dependencies
export -f add_current_snapshots_to_manifest generate_snapshot_entries_for_config

